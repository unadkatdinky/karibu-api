# Server Configuration
PORT=8080
ENVIRONMENT=development

# Database Configuration (Matches your TablePlus setup)
DB_HOST=localhost
DB_PORT=5432
# Change this to your Mac username if 'postgres' doesn't work
DB_USER=dinkyunadkat
DB_PASSWORD=1901
DB_NAME=karibu_db

# JWT Secrets (For local dev, these can be anything)
ACCESS_SECRET=karibu_local_access_super_secret
REFRESH_SECRET=karibu_local_refresh_super_secret

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
ACCESS_SECRET=your_access_secret_key_min_32_chars
REFRESH_SECRET=your_refresh_secret_key_min_32_chars
EMAIL_SECRET=your_email_secret_key_min_32_chars
RESET_SECRET=your_reset_secret_key_min_32_chars

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT=5
TOKEN_EXPIRY=15
REFRESH_EXPIRY=7

# Email (for sending verification/reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
