# Server Configuration
PORT=8080

# Database Configuration (Matches your TablePlus setup)
DB_HOST=localhost
DB_PORT=5432
# Change this to your Mac username if 'postgres' doesn't work
DB_USER=postgres
DB_PASSWORD=$$pl!1453
DB_NAME=karibu_db

# JWT Secrets (For local dev, these can be anything)
ACCESS_SECRET=karibu_local_access_super_secret
REFRESH_SECRET=karibu_local_refresh_super_secret